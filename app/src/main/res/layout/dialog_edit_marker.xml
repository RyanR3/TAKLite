<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_rounded_bg">

    <!-- Title -->
    <TextView
        android:id="@+id/editMarkerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Marker"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="@drawable/dialog_rounded_top" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editMarkerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF3A3A3A"
            android:textColor="@android:color/white"
            android:textColorHint="#666666"
            android:hint="Marker name"
            android:padding="12dp"
            android:singleLine="true"
            android:inputType="text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remarks"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editMarkerRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF3A3A3A"
            android:textColor="@android:color/white"
            android:textColorHint="#666666"
            android:hint="Add remarks..."
            android:padding="12dp"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <TextView
            android:id="@+id/editMarkerCoords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#777777"
            android:textSize="11sp"
            android:layout_marginTop="10dp" />

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        android:background="@drawable/dialog_rounded_bottom">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCEL"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btnSaveAndSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEND"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>
