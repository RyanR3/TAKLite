<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Title Bar -->
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titleBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="16dp">

            <!-- ============ IDENTITY SECTION ============ -->

            <!-- Callsign -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Callsign"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/takCallsign"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/background"
                android:hint="Your callsign"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Team Color -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Team Color"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/takTeamSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:layout_marginBottom="12dp"
                android:popupBackground="@color/surface" />

            <!-- Role -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Role"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/takRoleSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:layout_marginBottom="16dp"
                android:popupBackground="@color/surface" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background"
                android:layout_marginBottom="16dp" />

            <!-- ============ ENROLLMENT SECTION ============ -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Server Enrollment"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan QR code to connect to a TAK server"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/takEnrollQrButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Scan Enrollment QR Code"
                android:textSize="16sp"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/takEnrollStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- ============ GROUP ASSIGNMENT SECTION ============ -->

            <!-- Group Assignment -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Group Assignment"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fetch available groups from the server and assign this client"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/takFetchGroupsButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Fetch Groups"
                android:textSize="14sp"
                android:backgroundTint="@color/accent"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/takGroupCheckboxContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="4dp" />

            <Button
                android:id="@+id/takAssignGroupsButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Assign Selected Groups"
                android:textSize="14sp"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/takGroupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/background"
                android:layout_marginBottom="12dp" />

            <!-- ============ ADVANCED SETTINGS (collapsible) ============ -->

            <LinearLayout
                android:id="@+id/advancedHeader"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/advancedHeaderText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Advanced Settings"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/advancedArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Expand" />
            </LinearLayout>

            <!-- Advanced content (hidden by default) -->
            <LinearLayout
                android:id="@+id/advancedContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Server Address + Port -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Server"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/takServerAddress"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="3"
                        android:layout_marginEnd="8dp"
                        android:background="@color/background"
                        android:hint="Server address"
                        android:inputType="text"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/takServerPort"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@color/background"
                        android:hint="8089"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Manual Enrollment Credentials -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manual Enrollment"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/takEnrollUsername"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@color/background"
                    android:hint="TAK Username"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/takEnrollPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@color/background"
                    android:hint="TAK Password"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/takEnrollPort"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@color/background"
                    android:hint="Enrollment Port (default 8446)"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/takEnrollButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Enroll &amp; Download Certs"
                    android:textSize="14sp"
                    android:backgroundTint="@color/accent"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="12dp" />

                <!-- Manual Certificate Import -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manual Certificate Import"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <!-- Trust Store -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trust Store (.p12)"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/takTrustStoreButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Select File"
                        android:textSize="12sp"
                        android:backgroundTint="@color/accent"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/takTrustStoreLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No file selected"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:ellipsize="middle"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Client Certificate -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Client Certificate (.p12)"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/takClientCertButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Select File"
                        android:textSize="12sp"
                        android:backgroundTint="@color/accent"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/takClientCertLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No file selected"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:ellipsize="middle"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Certificate Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Certificate Password"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/takCertPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@color/background"
                    android:hint="atakatak"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Test Connection Button -->
                <Button
                    android:id="@+id/takTestConnectionButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Test Connection"
                    android:textSize="14sp"
                    android:backgroundTint="@color/accent"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
